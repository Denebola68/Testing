{
	"info": {
		"_postman_id": "1bb73ecc-863c-437e-8b1c-8d202de5da0d",
		"name": "API - Get user details",
		"description": "As an any active user of the application I would like to access all information tracked about myself [<b>via API</b>](https://czechitasda.docs.apiary.io/#reference/terms-collection/apitermstermid/get-single-term).\n\nBellow mentioned information will be shown about particular active user (his/her bearer token needs to be provided):\n\n- ID,\n    \n- Name,\n    \n- Email,\n    \n- If user is blocked or not,\n    \n- His/Her role,\n    \n- Date when the account was created,\n    \n- Date when the account was updated for the last time.",
		"schema": "https://schema.getpostman.com/json/collection/v2.0.0/collection.json"
	},
	"item": [
		{
			"name": "01_Happy path_all roles",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "d731a273-ec0d-4a43-92c6-be9389f2bb57",
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"var schema = {",
							"  \"type\": \"object\",",
							"  \"required\": [",
							"    \"id\",",
							"    \"name\",",
							"    \"email\",",
							"    \"role\"",
							"  ],",
							"  \"properties\": {",
							"    \"id\": {",
							"      \"type\": \"number\"",
							"    },",
							"    \"name\": {",
							"      \"type\": \"string\"",
							"    },",
							"    \"email\": {",
							"      \"type\": \"string\"",
							"    },",
							"    \"is_blocked\": {",
							"      \"type\": \"boolean\"",
							"    },",
							"    \"role\": {",
							"      \"type\": \"string\",",
							"      \"enum\": [",
							"        \"parent\",",
							"        \"master\",",
							"        \"admin\"",
							"      ],",
							"      \"description\": \"New user is always parent role\"",
							"    },",
							"    \"created_at\": {",
							"      \"type\": \"string\",",
							"      \"format\": \"date-time\",",
							"      \"description\": \"DateTime in RFC3339 format\"",
							"    },",
							"    \"updated_at\": {",
							"      \"type\": \"string\",",
							"      \"format\": \"date-time\",",
							"      \"description\": \"DateTime in RFC3339 format\"",
							"    }",
							"  },",
							"};",
							"",
							"pm.test(\"Check JSON structure and active status of user\", function () {",
							"    pm.response.to.have.jsonSchema(schema);",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.is_blocked).to.be.false;",
							"});",
							"",
							"console.log(\"Running as role:\", pm.iterationData.get(\"role\"));"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"id": "c19fda6c-9dd3-408a-9d30-7e3ad5d29ae1",
